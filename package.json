{
  "name": "blerp",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "This repository contains the planning and specification artifacts for the Blerp Identity Service (clean-room Clerk reimplementation). Start with the overview and follow links for deeper details:",
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "openapi:lint:spectral": "spectral lint openapi/blerp.v1.yaml --fail-severity=warn",
    "openapi:lint:redocly": "redocly lint openapi/blerp.v1.yaml --config=redocly.yaml",
    "openapi:lint": "bun run openapi:lint:spectral && bun run openapi:lint:redocly",
    "openapi:build": "redocly build-docs openapi/blerp.v1.yaml -o openapi/index.html",
    "sdk:generate": "cd packages/shared && bun run generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "bun@1.2.19",
  "devDependencies": {
    "@redocly/cli": "^2.19.2",
    "@stoplight/spectral-cli": "^6.15.0",
    "turbo": "^2.8.11"
  }
}