{
  "name": "@blerp/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate-all": "bun run scripts/db-admin.ts migrate-all",
    "db:seed": "bun run scripts/db-admin.ts seed"
  },
  "dependencies": {
    "@blerp/shared": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "5.0.0-beta.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@blerp/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.4.5"
  },
  "type": "module"
}
