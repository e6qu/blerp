{
  "name": "@blerp/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate-all": "bun run scripts/db-admin.ts migrate-all",
    "db:seed": "bun run scripts/db-admin.ts seed",
    "test": "vitest run",
    "worker": "bun run src/worker.ts"
  },
  "dependencies": {
    "@blerp/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "drizzle-orm": "^0.45.1",
    "express": "5.0.0-beta.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6",
    "otplib": "^13.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@blerp/config": "workspace:*",
    "@types/argon2": "^0.15.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/pino-http": "^6.1.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "type": "module"
}
