# Blerp Configuration (preferred)
# These take priority over CLERK_* equivalents
NEXT_PUBLIC_BLERP_PUBLISHABLE_KEY=pk_test_your_publishable_key
BLERP_API_URL=http://localhost:3000
BLERP_SECRET_KEY=sk_test_your_secret_key
BLERP_WEBHOOK_SECRET=whsec_your_webhook_secret

# Clerk-compatible Configuration (optional)
# Use these for drop-in Clerk compatibility
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# CLERK_API_URL=http://localhost:3000
# CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Monite Configuration (optional - if not provided, mock tokens will be used)
# Get credentials from https://dashboard.monite.com
MONITE_API_URL=https://api.sandbox.monite.com
MONITE_CLIENT_ID=your_monite_client_id
MONITE_CLIENT_SECRET=your_monite_client_secret
MONITE_VERSION=2023-03-14
